{
  "manifest_version": 3,
  "name": "LinkedIn Profile Analyzer",
  "version": "3.0.0",
  "description": "Analyze any LinkedIn profile with AI — get summaries, outreach strategies, and compatibility scores.",
  "permissions": [
    "activeTab",
    "storage",
    "sidePanel",
    "tabs"
  ],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "http://localhost:5000/*",
    "http://127.0.0.1:5000/*"
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16":  "icons/logo.png",
    "48":  "icons/logo.png",
    "128": "icons/logo.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "icons/logo.png",
        "icons/banner.png",
        "sidepanel.js"
      ],
      "matches": [
        "https://www.linkedin.com/*",
        "chrome-extension://*/*"
      ]
    }
  ]
}