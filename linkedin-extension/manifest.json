{
    "manifest_version": 3,
    "name": "LinkedIn Profile Analyzer",
    "version": "1.0.0",
    "description": "Analyze any LinkedIn profile with AI — get summaries, outreach strategies, and compatibility scores.",
    "permissions": [
        "activeTab",
        "storage"
    ],
    "host_permissions": [
        "https://www.linkedin.com/*",
        "http://localhost:5000/*",
        "http://127.0.0.1:5000/*"
    ],
    "content_scripts": [
        {
            "matches": [
                "https://www.linkedin.com/in/*"
            ],
            "js": [
                "content.js"
            ],
            "css": [
                "styles.css"
            ],
            "run_at": "document_idle"
        }
    ],
    "background": {
        "service_worker": "background.js"
    },
    "icons": {
        "16": "icons/logo.png",
        "48": "icons/logo.png",
        "128": "icons/logo.png"
    },
    "web_accessible_resources": [
        {
            "resources": [
                "icons/logo.png",
                "icons/banner.png"
            ],
            "matches": [
                "https://www.linkedin.com/*"
            ]
        }
    ]
}